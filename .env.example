# Lokasi berkas database SQLite, relatif terhadap root proyek.
DATABASE_URL=file:./itsa-web.db

# Kunci untuk mengenkripsi token login. WAJIB diisi dan sebaiknya berbeda
# di tiap mesin. Buat nilai acak dengan:  openssl rand -hex 32
PAYLOAD_SECRET=ISI_DENGAN_NILAI_ACAK

# Dipakai untuk CORS dan pembentukan tautan. Tanpa garis miring di akhir.
# Kalau menjalankan di port selain 3000, ubah juga nilai ini, lalu hapus
# folder .next sebelum menjalankan ulang.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Kunci untuk mengautentikasi cron job.
CRON_SECRET=ISI_DENGAN_NILAI_ACAK

# Kunci untuk memvalidasi permintaan preview dari panel admin.
PREVIEW_SECRET=ISI_DENGAN_NILAI_ACAK
